name      = "prod"
region    = "us-east-2"
install_key = "get_me_from_cake"

# CIDR block for the new VPC. The default below is fine for a standalone VPC.
# Change it if you intend to peer this VPC with another one that uses a
# conflicting range (peered VPCs cannot have overlapping CIDRs).
vpc_cidr = "10.0.0.0/16"

cake_agents_chart_version = "0.11.0"

# An arbitrary string used to identify the provider in Cake Agents. In the
# future, we will support multiple SSO providers, and this ID will be used to
# distinguish between them. For now, it can just be "oidc".
oidc_provider_id = "oidc"
# Set to require users log in with an email address from a specific domain
# (e.g. your company SSO).
oidc_domain = "example.com"
# The OIDC issuer URL. This is the URL that Cake Agents will use to fetch the
# provider's public keys and verify tokens. It must be a valid OIDC issuer that
# conforms to the OIDC discovery spec (i.e. it must have a well-known
# configuration endpoint at `${issuer}/.well-known/openid-configuration`).
oidc_issuer = "https://oidc.example.com"
# The client ID that Cake Agents will expect in the OIDC token. This should
# match the client ID configured in your OIDC provider for the Cake Agents
# application.
oidc_client_id = "cake-agents"
# The client secret associated with the above client ID. Only needed if
# oidc_public_client is false.
oidc_client_secret = "get_me_from_your_oidc_provider"
# Set to true if your OIDC provider does not require a client secret, and leave
# oidc_client_secret blank in that case.
oidc_public_client = false
