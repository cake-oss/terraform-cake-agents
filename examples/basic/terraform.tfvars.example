cake_agents_chart_version = "0.11.2"

name        = "cake-agents"
region      = "us-east-2"
install_key = "get_me_from_https://console.cake.ai"

cake_console_url = "https://console.cake.ai"

# Optional override for the cake-agents container image tag. Leave unset to
# default the image tag to cake_agents_chart_version.
# cake_agents_image_tag = "0.11.2"

# CIDR block for the new VPC. The default below is fine for a standalone VPC.
# Change it if you intend to peer this VPC with another one that uses a
# conflicting range (peered VPCs cannot have overlapping CIDRs).
# vpc_cidr = "10.0.0.0/16"

# Optional OIDC configuration for the cake-agents Helm chart. When unset, no
# OIDC block is passed and only email/password auth is available.
# oidc = {
#   provider_id   = "google"
#   domain        = "example.com"
#   issuer        = "https://accounts.google.com"
#   client_id     = "874461285778-q1r838cptfghrb3qlvkv6mvpjspg8b1p.apps.googleusercontent.com"
#   client_secret = "GOCSPX-..."
#   public_client = false
#   scopes        = ["openid", "email", "profile"]
# }

# Additional hosts appended to controlPlane.extraHosts. The OIDC issuer host is
# added automatically.
# extra_hosts = [
#   "https://oauth2.googleapis.com",
#   "https://www.googleapis.com",
#   "https://openidconnect.googleapis.com",
# ]
