# Cluster name. Names the EKS cluster and tags the supporting AWS resources, so
# pick something that identifies this deployment in your AWS account.
name = "cake-agents"

# AWS region to deploy into. All resources are created here, so use a region
# close to your users. Independent of your AWS CLI default region.
region = "us-east-2"

# Install key for Cake-hosted DNS automation. Get it from https://console.cake.ai
install_key = "get_me_from_https://console.cake.ai"

# CIDR block for the new VPC. The default below is fine for a standalone VPC.
# Change it if you intend to peer this VPC with another one that uses a
# conflicting range (peered VPCs cannot have overlapping CIDRs).
# vpc_cidr = "10.0.0.0/16"
